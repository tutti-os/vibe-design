{
  "schemaVersion": "tutti.app.cli.v1",
  "scope": "vibe-design",
  "documentation": {
    "file": "COMMANDS.md"
  },
  "commands": [
    {
      "path": ["projects"],
      "summary": "List Prototype Design projects",
      "description": "List projects in the current Prototype Design workspace.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "description": "Maximum number of projects to return." }
        }
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/projects", "timeoutMs": 30000 }
    },
    {
      "path": ["project-create"],
      "summary": "Create a Prototype Design project",
      "description": "Create a new project from a prompt and initialize its default conversation. Returns the project and the created conversationId.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": { "type": "string", "description": "Design prompt describing the prototype to build." },
          "title": { "type": "string", "description": "Optional project title. Defaults to the prompt." },
          "project-kind": { "type": "string", "description": "Optional project kind." },
          "design-system-id": { "type": "string", "description": "Optional design system id to apply." }
        },
        "required": ["prompt"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/project-create", "timeoutMs": 30000 }
    },
    {
      "path": ["session-start"],
      "summary": "Send a message and run the agent",
      "description": "Send a prompt into a project conversation and run the agent to completion, then return the full agent conversation messages. When conversation-id is omitted, a conversation is created automatically before sending. Provider availability is checked first; if the requested agent is unavailable the call automatically falls back to another available provider (see agentSwitched in the result). This call is synchronous: it waits for the run to finish.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." },
          "prompt": { "type": "string", "description": "Message to send to the agent (alias: message)." },
          "conversation-id": { "type": "string", "description": "Optional conversation id. When omitted, a conversation is created and the message is sent to it." },
          "agent-id": { "type": "string", "description": "Optional agent type / provider id (e.g. codex or claude). Defaults to the server default. If the chosen provider is unavailable the call falls back to another available provider." },
          "model": { "type": "string", "description": "Optional model id (provider-specific; dropped if the provider is switched by fallback)." }
        },
        "required": ["project-id"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/session-start", "timeoutMs": 300000 }
    },
    {
      "path": ["conversations"],
      "summary": "List project conversations",
      "description": "List conversations for one project.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." }
        },
        "required": ["project-id"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/conversations", "timeoutMs": 30000 }
    },
    {
      "path": ["conversation-messages"],
      "summary": "Get conversation messages",
      "description": "Return all messages in a project conversation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." },
          "conversation-id": { "type": "string", "description": "Conversation id." }
        },
        "required": ["project-id", "conversation-id"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/conversation-messages", "timeoutMs": 30000 }
    },
    {
      "path": ["files"],
      "summary": "List project resources",
      "description": "List file resources for one project, including each resource's static HTTP URL.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." }
        },
        "required": ["project-id"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/files", "timeoutMs": 30000 }
    },
    {
      "path": ["file-get"],
      "summary": "Get a project resource",
      "description": "Return a file resource. Text files use utf8; binary files use base64.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." },
          "name": { "type": "string", "description": "File name." }
        },
        "required": ["project-id", "name"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/file-get", "timeoutMs": 30000 }
    },
    {
      "path": ["comments"],
      "summary": "List preview comments",
      "description": "List comments for a project conversation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project-id": { "type": "string", "description": "Project id." },
          "conversation-id": { "type": "string", "description": "Conversation id." }
        },
        "required": ["project-id", "conversation-id"]
      },
      "output": { "defaultMode": "json", "json": true },
      "handler": { "kind": "http", "method": "POST", "path": "/tutti/cli/comments", "timeoutMs": 30000 }
    }
  ]
}
