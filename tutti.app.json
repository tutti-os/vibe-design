{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "vibe-design",
  "version": "0.1.32",
  "name": "Vibe Design",
  "description": "Create and iterate on design prototypes inside a Tutti workspace.",
  "localizationInfo": {
    "defaultLocale": "en",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  },
  "icon": {
    "type": "asset",
    "src": "icon.png"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/healthz"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "author": {
    "name": "Tutti"
  },
  "tags": [
    "design",
    "prototype",
    "workspace"
  ]
}
